<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net" type="device">
  <diagram id="provisioning-flow" name="Provisioning flow">
    <mxGraphModel dx="1422" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="980" pageHeight="800" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- ===== Account / site boundaries (drawn first = behind lifelines) ===== -->
        <mxCell id="acct-customer" value="Customer site" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;fillColor=#EAF2FB;strokeColor=#6C8EBF;verticalAlign=top;fontStyle=1;fontSize=12;spacingTop=4;arcSize=4;" vertex="1" parent="1">
          <mxGeometry x="30" y="15" width="200" height="695" as="geometry"/>
        </mxCell>
        <mxCell id="acct-fleet" value="Fleet-management AWS account" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;fillColor=#FFF9E6;strokeColor=#D6B656;verticalAlign=top;fontStyle=1;fontSize=12;spacingTop=4;arcSize=4;" vertex="1" parent="1">
          <mxGeometry x="248" y="15" width="424" height="695" as="geometry"/>
        </mxCell>
        <mxCell id="acct-tenant" value="Tenant AWS account&#10;(1 of N — one identical account per tenant)" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;fillColor=#FBEAE8;strokeColor=#B85450;verticalAlign=top;fontStyle=1;fontSize=12;spacingTop=4;arcSize=4;" vertex="1" parent="1">
          <mxGeometry x="688" y="15" width="200" height="695" as="geometry"/>
        </mxCell>

        <!-- ===== Lifelines ===== -->
        <mxCell id="dev" value="Device" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="180" height="700" as="geometry"/>
        </mxCell>
        <mxCell id="claim" value="Claim broker&lt;br&gt;(AWS IoT, mTLS)&lt;br&gt;provision.factbird.com" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="260" y="40" width="180" height="700" as="geometry"/>
        </mxCell>
        <mxCell id="router" value="Fleet-mgmt Router&lt;br&gt;+ claim_reactor" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="40" width="180" height="700" as="geometry"/>
        </mxCell>
        <mxCell id="tenant" value="Tenant broker&lt;br&gt;(AWS IoT, custom auth)" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="700" y="40" width="180" height="700" as="geometry"/>
        </mxCell>

        <!-- ===== Phase 1: Routing ===== -->
        <mxCell id="phase1" value="(1) Routing — claim-cert mTLS, ALPN x-amzn-mqtt-ca" style="text;html=1;align=left;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="120" width="540" height="20" as="geometry"/>
        </mxCell>

        <mxCell id="msg1" value="connect (mTLS, claim cert)" style="endArrow=classic;html=1;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="130" y="155" as="sourcePoint"/>
            <mxPoint x="350" y="155" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <mxCell id="msg2" value="PUB provision/{uuid}/request&#10;(empty body)" style="endArrow=classic;html=1;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="130" y="195" as="sourcePoint"/>
            <mxPoint x="570" y="195" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <mxCell id="msg3" value="SUB provision/{uuid}/response" style="endArrow=classic;html=1;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="130" y="245" as="sourcePoint"/>
            <mxPoint x="570" y="245" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <mxCell id="msg4" value="PUB provision/{uuid}/response&#10;{ iotDataEndpoint, provisioningToken, ... }&#10;(immediate, or pushed later by claim_reactor on DDB stream)" style="endArrow=classic;html=1;rounded=0;strokeColor=#82B366;fontColor=#23445D;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="570" y="295" as="sourcePoint"/>
            <mxPoint x="130" y="295" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <mxCell id="msg5" value="disconnect" style="endArrow=classic;html=1;rounded=0;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="130" y="345" as="sourcePoint"/>
            <mxPoint x="350" y="345" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- ===== Phase 2: Custom-auth provisioning ===== -->
        <mxCell id="phase2" value="(2) Provisioning — custom authorizer, ALPN mqtt, no client cert" style="text;html=1;align=left;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="385" width="600" height="20" as="geometry"/>
        </mxCell>

        <mxCell id="msg6" value="connect (TLS, no cert)&#10;username = uuid&#10;password = sig:token" style="endArrow=classic;html=1;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="130" y="430" as="sourcePoint"/>
            <mxPoint x="790" y="430" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <mxCell id="msg7" value="CreateCertificateFromCsr / RegisterThing&#10;(AWS IoT Fleet Provisioning)" style="endArrow=classic;startArrow=classic;html=1;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="130" y="490" as="sourcePoint"/>
            <mxPoint x="790" y="490" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <mxCell id="msg8" value="disconnect" style="endArrow=classic;html=1;rounded=0;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="130" y="535" as="sourcePoint"/>
            <mxPoint x="790" y="535" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- ===== Phase 3: Production ===== -->
        <mxCell id="phase3" value="(3) Production — mTLS production cert, ALPN x-amzn-mqtt-ca" style="text;html=1;align=left;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="575" width="600" height="20" as="geometry"/>
        </mxCell>

        <mxCell id="msg9" value="connect (mTLS, production cert)" style="endArrow=classic;html=1;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="130" y="620" as="sourcePoint"/>
            <mxPoint x="790" y="620" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <mxCell id="msg10" value="normal MQTT traffic" style="endArrow=classic;startArrow=classic;html=1;rounded=0;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="130" y="670" as="sourcePoint"/>
            <mxPoint x="790" y="670" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- ===== Footnote ===== -->
        <mxCell id="note" value="Phase 1's subscription stays open across Router error responses with code &lt;b&gt;notClaimed&lt;/b&gt;;&#10;claim_reactor publishes the success payload when the DynamoDB claim transition fires." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;fillColor=#FFF2CC;strokeColor=#D6B656;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="715" width="600" height="55" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
